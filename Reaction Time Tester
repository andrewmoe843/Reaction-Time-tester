#include "LedControl.h"
#include "SevSeg.h"

#define NOTE_D3  147
#define NOTE_D4  294

const int Button_Pin = 14;
const int buzzpin = 15;
int High_Score = 9999;
unsigned long timer;

SevSeg sevseg; 


void setup()
{
    Serial.begin(115200);

    byte numDigits = 4;
    byte digitPins[] = {2, 3, 4, 5};
    byte segmentPins[] = {6, 7, 8, 9, 10, 11, 12, 13};
    bool resistorsOnSegments = true;
    byte hardwareConfig = COMMON_CATHODE;
    bool updateWithDelays = false;
    bool leadingZeros = false;
    bool disableDecPoint = true; 

    sevseg.begin(hardwareConfig, numDigits, digitPins, segmentPins, resistorsOnSegments,
                 updateWithDelays, leadingZeros, disableDecPoint);
    sevseg.setBrightness(90);
    pinMode(Button_Pin, INPUT_PULLUP);
    randomSeed(analogRead(A5));
}



void printNumber(int v)
{
    if (v > 9999) return;

    sevseg.setNumber(v, 0);
    sevseg.refreshDisplay();
}



void Get_Ready()
{
    for (int repeat = 0; repeat < 6; repeat++)
    {
    	tone(buzzpin, repeat * 250, 20);
    	// flash 8888 
        printNumber(8888);
        millis_delay(50);
        sevseg.blank();
        millis_delay(50);
    }
}


void Start_Counting()
{
    long counter = millis();
    int Score;
    int freq = 250;
    while (digitalRead(Button_Pin) == HIGH) 
    {
        Score = int(millis() - counter);
        if (Score > 9999)
        {
            fail();
            return;
        }
        printNumber(Score);
        if (freq < 2000)
        {
            tone(buzzpin, freq);
            freq += 1;
        }
        else
        {
            noTone(buzzpin);
        }
    }
    noTone(buzzpin);

    if (Score < High_Score)
    {
        High_Score = Score;
        win();
    }
    else  fail(); 

    noTone(buzzpin);
}



void millis_delay(int wait_time)
{
    
    timer = millis();
    while (millis() - timer < wait_time)
    {
        sevseg.refreshDisplay();
    }
}



void fail()
{
    
    tone(buzzpin, NOTE_D4);
    millis_delay(500);
    tone(buzzpin, NOTE_D3);
    millis_delay(1000);
    noTone(buzzpin);
    millis_delay(2000);
}



void win()
{
    for (int x = 0; x < 10; x++)
    {
        int freq = 200;
        while (freq < 2000) 
        {
            tone(buzzpin, freq);
            freq += 150;
            millis_delay(50);
        }
    }
}



void loop()
{
    int counter = 0;
    while (digitalRead(Button_Pin) == HIGH)
    {
        if (counter == 0)    sevseg.blank();
        if (counter == 10000) printNumber(High_Score); 
        sevseg.refreshDisplay();
        counter++;
        if (counter > 20000) counter = 0;
    }
    
    Get_Ready();
    delay(2000); 
    delay(random(8000)); 
    Start_Counting();
}
